# Vision USB Gateway config
# Copy to /etc/vision-gw.conf and edit.

# Repo home for scripts
GATEWAY_HOME=/opt/vision-usb-gateway

# NVMe and LVM (1TB NVMe defaults)
NVME_DEVICE=/dev/nvme0n1
LVM_VG=vg0
MIRROR_LV=mirror
MIRROR_MOUNT=/srv/vision_mirror
MIRROR_SIZE=300G
THINPOOL_LV=usbpool
THINPOOL_SIZE=650G
THINPOOL_META_SIZE=8G
USB_LVS=(usb_0 usb_1 usb_2)
USB_LABEL=VISIONUSB
USB_LV_SIZE=100G
USB_ACTIVE_PERSIST=/srv/vision_mirror/.state/vision-usb-active

# FAT32 volume serial — DEPRECATED.  Scripts now generate a unique random
# serial on every mkfs.vfat call so the host OS (Windows) never serves
# stale cached directory data after LV rotation.  Drive letter persistence
# is maintained by the USB gadget device identity, not the FAT serial.
# This value is ignored by clone-usb-format.sh and offline-maint.sh.
# USB_VOLUME_SERIAL=DEADBEEF

# USB gadget
USB_GADGET_NAME=vision
USB_VENDOR_ID=0x1d6b
USB_PRODUCT_ID=0x0104
USB_MANUFACTURER=VisionGateway
USB_PRODUCT=VisionUSBStorage
USB_SERIAL=CM5-0001
USB_CONFIG="Config 1"
USB_MAX_POWER=250

# Snapshot sync
SYNC_SNAPSHOT_NAME=usb_sync_snap
SYNC_MOUNT=/mnt/vision_snap
SYNC_INTERVAL_SEC=2min
SYNC_ONBOOT_SEC=2min
SYNC_ONACTIVE_SEC=2min
SYNC_HI_INTERVAL_SEC=10s
FAST_SYNC_MIN_ON_SCANS=3
FAST_SYNC_COOLDOWN_SCANS=2
FAST_SYNC_EXIT_DELTA=5
SYNC_CHANGE_DETECT=false
SYNC_MANIFEST_FILE=/srv/vision_mirror/.state/usb_sync.manifest
SYNC_CHANGE_RESUME_SCANS=2
STABLE_SCAN_REQUIRED=2
MAX_FILE_SIZE_BYTES=4294967296
COPY_CHUNK_BYTES=8388608
SYNC_LOG_EVERY=0
SYNC_SCAN_DEPTH=1
SYNC_HOT_DIRS=1
SYNC_COLD_AUDIT_DIRS_PER_RUN=1
SYNC_DIR_INDEX_FILE=/srv/vision_mirror/.state/sync-dir-index.json
RAW_APPEND_ALWAYS=false
BYDATE_USE_FILE_TIME=false

# USB LV persist (folder preserved across rotations)
USB_PERSIST_DIR=aoi_settings
USB_PERSIST_BACKING=/srv/vision_mirror/.state/aoi_settings
USB_PERSIST_DURATION_FILE=/srv/vision_mirror/aoi_settings_duration.txt

# Rotation thresholds (percent)
THRESH_HI=80
THRESH_CRIT=92
THRESH_HI_STABLE_SCANS=3
META_HI=70
META_CRIT=85
SWITCH_WINDOW_START=00:00
SWITCH_WINDOW_END=23:59
# Delay (seconds) between forced_eject and new media presentation.
# 0 = silent switch (relies on unique FAT serials), 1-2 = Windows SCSI gap.
SWITCH_DELAY_SEC=0

# Mirror retention
RETENTION_HI=90
RETENTION_LO=85
DB_MAINT_INTERVAL_SEC=86400
FILE_STATE_PRUNE_DAYS=30

# NAS optional
NAS_ENABLED=false
NAS_MOUNT=/mnt/nas
NAS_REMOTE=//nas/vision
NAS_CREDENTIALS=/etc/vision-nas.creds
NAS_RSYNC_OPTS="-aH --partial --inplace --timeout=30"
NAS_RETRY_MAX=5
NAS_RETRY_BACKOFF=10

# RTC
# The unit is offline by design, so the RTC is its only source of wall-clock time
# across a power cut — without it the clock rewinds to whatever was baked into the
# image and files land under the wrong bydate/ folder. Needs a backup cell on the
# carrier's RTC header (official RTC-Battery-B / ML2032); the SoC's charger is off
# until 15_configure_rtc.sh enables it. Never charge a non-rechargeable CR2032 —
# set RTC_CHARGE_ENABLED=false if one is fitted.
RTC_ENABLED=true
RTC_DEVICE=/dev/rtc0
RTC_UTC=true
RTC_SYNC_INTERVAL=1h
RTC_CHARGE_ENABLED=true
RTC_CHARGE_UV=3000000

# USB export: plug a drive into one of the HOST ports (NOT the AOI's OTG port) and
# it is mounted here automatically, so mirror data can be copied off by hand. The
# gadget's LVs, the NVMe and the eMMC can never be picked up: the udev rule matches
# ID_BUS=usb only, and usb-export-mount.sh re-checks. exFAT and NTFS both use
# in-kernel drivers (exfat, ntfs3) — no FUSE package needed.
# USB_EXPORT_SYNC mounts write-through, so a drive stays consistent and survives
# being yanked out mid-copy — which, on a shop floor, it eventually will be. It
# is not free: measured on a real stick, 7 MB/s vs 24 MB/s, i.e. 4.6 hours rather
# than 1.4 for a 117 GB drive. Set it false if that trade stops being worth it;
# the WebUI's eject button covers the same risk for anyone who uses it.
USB_EXPORT_ENABLED=true
USB_EXPORT_MOUNT=/srv/usb_backup
USB_EXPORT_SYNC=true

# Journald (overlay mode memory cap)
JOURNAL_RUNTIME_MAX_USE=64M
JOURNAL_RUNTIME_KEEP_FREE=32M
OVERLAY_CLEAN_LOGS_ON_ENABLE=true

# Samba
SMB_BIND_INTERFACE=eth0
SMB_USER=smbuser
# NetBIOS + WSDD
NETBIOS_NAME=CITOSTORE
SMB_WORKGROUP=WORKGROUP
# Web UI
WEBUI_BIND=0.0.0.0
WEBUI_PORT=80

# mDNS / zeroconf (.local name resolution). Lets a laptop reach the unit by name
# with no router and no client config (Windows 10/11 resolve .local natively). The
# advertised name is always NETBIOS_NAME (AOI1 -> AOI1.local), on a network and on
# a direct link alike. avahi is restricted to MDNS_INTERFACE so the isolated eth1
# address is never advertised.
MDNS_ENABLED=true
MDNS_INTERFACE=eth0
# On a direct 1-1 link (no router) the unit serves DHCP itself on MDNS_DIRECT_SUBNET
# (taking .1) so a laptop set to "automatic" gets a real address. Decided once at
# boot: MDNS_NETWORK_WAIT_SEC is how long to wait for a lease before concluding
# there is no network — too short and a unit on a LAN whose DHCP is slow (switch
# port negotiation, spanning-tree) serves rogue DHCP on that LAN. A lease ends the
# wait immediately, so a normal network costs nothing. A unit that lives on a LAN
# should get a fixed IP: a static address is always "network", so it never serves DHCP.
MDNS_DIRECT_DHCP=true
MDNS_DIRECT_SUBNET=10.10.10
MDNS_NETWORK_WAIT_SEC=45
# SMB_PASS is required to create the Samba user non-interactively.
# SMB_PASS=change-me

# Second Ethernet (eth1): isolated network for an Ethernet AOI that pushes
# files directly via FTP/SFTP. Static IP; leave the gateway empty when isolated.
ETH1_ENABLED=false
ETH1_INTERFACE=eth1
ETH1_ADDRESS=192.168.100.1
ETH1_PREFIX=24
ETH1_GATEWAY=

# Direct ingest from an Ethernet AOI (NAS-like: files are stored as they arrive
# under INGEST_DIR/data, served over SMB, and covered by mirror retention).
INGEST_ENABLED=false
INGEST_DIR=/srv/vision_mirror/ingest
FTP_ENABLED=false
SFTP_ENABLED=false
FTP_USER=aoiftp
# FTP/SFTP bind to eth1 only. The password is NOT stored here (shell-sourced);
# it lives in the shadow secret file and is applied on boot.
FTP_BIND_INTERFACE=eth1
FTP_PASV_MIN_PORT=30000
FTP_PASV_MAX_PORT=30020
